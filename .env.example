NEXT_PUBLIC_API_URL=http://localhost:8080

# Multi-tenancy phase 7 (Butcher-Multi-Tenancy-Plan.md §3).
#
# The root domain shops live under, e.g. butchercashier.com — so that
# alaqsa.butchercashier.com is recognised as the shop "alaqsa".
#
# LEAVE THIS UNSET until wildcard DNS is actually live. While it's unset the
# app sends no organization header and behaves exactly as a single-tenant
# deployment. Setting it on a host that ISN'T a subdomain of this domain does
# nothing (the check requires a real suffix match) — which is deliberate, after
# an earlier heuristic version read "butcher-frontend-eight" out of
# butcher-frontend-eight.vercel.app and locked every user out.
#
# The backend has a matching CORS_WILDCARD_DOMAIN; set both together.
# NEXT_PUBLIC_ROOT_DOMAIN=butchercashier.com
